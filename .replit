modules = ["nodejs-20", "web", "bash", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 23236
externalPort = 80

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "PORT=8080 node --enable-source-maps artifacts/api-server/dist/index.js"]
build = ["bash", "-c", "pnpm install && pnpm --filter @workspace/parisa-portal run build && pnpm --filter @workspace/api-server run build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 node --enable-source-maps artifacts/api-server/dist/index.js & PORT=5000 pnpm --filter @workspace/parisa-portal run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "PORT=5000 pnpm --filter @workspace/parisa-portal run dev"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PORT=5000 pnpm --filter @workspace/parisa-portal run dev"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"
